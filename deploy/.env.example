MFM_DOMAIN=files.example.com
MFM_DATA_PATH=/srv/material-file-manager/data

OIDC_ISSUER_URI=https://accounts.google.com
OIDC_CLIENT_ID=replace-with-client-id
OIDC_CLIENT_SECRET=replace-with-client-secret

# Prefer issuer|subject once the identity is known.
MFM_ALLOWED_IDENTITIES=
MFM_ALLOWED_EMAILS=owner@example.com
